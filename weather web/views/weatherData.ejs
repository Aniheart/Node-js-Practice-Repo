<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Today's weather</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-blue-600 to-purple-700 font-sans">
    <% weatherData.forEach((weather) => { %>
    <div class="min-h-screen flex justify-center items-center p-5">
        <div class="bg-white rounded-3xl shadow-2xl p-10 max-w-sm w-full">
            <div class="text-3xl font-bold text-gray-800 mb-5 text-center"><%= weather.City%></div>
            <div class="text-2xl text-gray-600 text-center mb-8 flex items-center justify-center gap-2">
                <span class="text-4xl">☁️</span>
                <span><%= weather.Clouds%></span>
            </div>
            <div class="grid grid-cols-2 gap-5 mb-5">
                <div class="bg-gray-100 rounded-xl p-4 text-center">
                    <div class="text-xs text-gray-500 uppercase font-bold mb-2">Humidity</div>
                    <div class="text-2xl font-bold text-gray-800"><%= weather.Humidity%></div>
                </div>
                <div class="bg-gray-100 rounded-xl p-4 text-center">
                    <div class="text-xs text-gray-500 uppercase font-bold mb-2">Wind Speed</div>
                    <div class="text-2xl font-bold text-gray-800"><%= weather.Wind_speed%>Km/H</div>
                </div>
            </div>
            <div class="bg-gray-100 rounded-xl p-4 text-center">
                <div class="text-xs text-gray-500 uppercase font-bold mb-2">Cloudiness</div>
                <div class="text-2xl font-bold text-gray-800"><%= weather.Cloudy%></div>
            </div>
        </div>
    </div>
    <% }) %>
</body>
</html>